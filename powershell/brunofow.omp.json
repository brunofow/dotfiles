{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "path",
          "style": "plain",
          "foreground": "#56B6C2",
          "options": { "style": "folder" },
          "template": "  {{ .Path }}"
        },
        {
          "type": "git",
          "style": "plain",
          "foreground": "#D0666F",
          "options": { "branch_icon": "", "fetch_status": true },
          "template": " <#5FAAE8>git:(</>{{ .HEAD }}{{ if .Working.Changed }} <#FFEB3B>{{ .Working.String }}</>{{ end }}<#5FAAE8>)</>{{ if or .Working.Changed .Staging.Changed }} <#FFEB3B>✗</>{{ end }}"
        },
        {
          "type": "text",
          "style": "plain",
          "template": "\n"
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "foreground": "#98C379",
          "template": "➜"
        }
      ]
    }
  ],
  "final_space": true,
  "version": 4
}
